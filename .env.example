# ==========================================
# SKEP - 산업현장 장비 투입 관리 플랫폼
# Environment Variables Template
# ==========================================

# Environment
ENVIRONMENT=dev
DOMAIN=skep.on1.kr

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=skep_db
DB_USERNAME=skep_user
DB_PASSWORD=change_me_in_production
DB_POOL_SIZE=20
DB_MAX_IDLE_TIME=600
DB_SSL_MODE=disable

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=2000

# ==========================================
# JWT Configuration
# ==========================================
JWT_SECRET=your-256bit-base64-encoded-secret-key-here-change-in-production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ==========================================
# AWS Configuration
# ==========================================
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=skep-documents-dev
AWS_S3_REGION=ap-northeast-2
AWS_SES_FROM_EMAIL=noreply@skep.on1.kr
AWS_SES_REGION=ap-northeast-2

# ==========================================
# External Services
# ==========================================
OCR_SERVICE_URL=http://ocr-service:8089
OCR_SERVICE_TIMEOUT=30000
GOVAPI_SERVICE_URL=http://govapi-service:8090
GOVAPI_SERVICE_TIMEOUT=10000

# ==========================================
# FCM (Firebase Cloud Messaging)
# ==========================================
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_PRIVATE_KEY_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# Metrics & Monitoring
# ==========================================
ACTUATOR_ENABLED=true
PROMETHEUS_ENABLED=true

# ==========================================
# API Gateway Configuration
# ==========================================
API_GATEWAY_PORT=8080
API_GATEWAY_TIMEOUT=30000
API_GATEWAY_CIRCUIT_BREAKER_ENABLED=true

# ==========================================
# Auth Service Configuration
# ==========================================
AUTH_SERVICE_PORT=8081
OAUTH_ENABLED=false
LDAP_ENABLED=false

# ==========================================
# Document Service Configuration
# ==========================================
DOCUMENT_SERVICE_PORT=8082
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# ==========================================
# Equipment Service Configuration
# ==========================================
EQUIPMENT_SERVICE_PORT=8083
EQUIPMENT_CACHE_TTL_MINUTES=60

# ==========================================
# Dispatch Service Configuration
# ==========================================
DISPATCH_SERVICE_PORT=8084
DISPATCH_NOTIFICATION_ENABLED=true

# ==========================================
# Inspection Service Configuration
# ==========================================
INSPECTION_SERVICE_PORT=8085
INSPECTION_CACHE_TTL_MINUTES=30

# ==========================================
# Settlement Service Configuration
# ==========================================
SETTLEMENT_SERVICE_PORT=8086
SETTLEMENT_BATCH_ENABLED=true
SETTLEMENT_BATCH_CRON=0 2 * * *

# ==========================================
# Notification Service Configuration
# ==========================================
NOTIFICATION_SERVICE_PORT=8087
NOTIFICATION_BATCH_SIZE=100
EMAIL_ENABLED=true
SMS_ENABLED=false

# ==========================================
# Location Service Configuration
# ==========================================
LOCATION_SERVICE_PORT=8088
LOCATION_UPDATE_INTERVAL_SECONDS=60
LOCATION_CACHE_TTL_MINUTES=10

# ==========================================
# OCR Service (Mock) Configuration
# ==========================================
OCR_SERVICE_PORT=8089
OCR_MOCK_ENABLED=true

# ==========================================
# Government API Service (Mock) Configuration
# ==========================================
GOVAPI_SERVICE_PORT=8090
GOVAPI_MOCK_ENABLED=true

# ==========================================
# Frontend Configuration
# ==========================================
FRONTEND_PORT=3000
FLUTTER_BUILD_MODE=debug

# ==========================================
# Slack Integration (Optional)
# ==========================================
SLACK_WEBHOOK_URL=
SLACK_ENABLED=false

# ==========================================
# Security
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type
CORS_MAX_AGE=3600

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BY_IP=true

# ==========================================
# Cache Configuration
# ==========================================
CACHE_TYPE=redis
CACHE_TTL_MINUTES=60
CACHE_MAX_SIZE=10000

# ==========================================
# Mail Configuration
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@skep.on1.kr
MAIL_FROM_NAME=SKEP Platform
MAIL_PROTOCOL=smtp

# ==========================================
# Business Configuration
# ==========================================
COMPANY_NAME=SKEP Platform
COMPANY_PHONE=+82-1234-5678
COMPANY_ADDRESS=Seoul, South Korea
